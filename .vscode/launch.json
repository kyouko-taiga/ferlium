{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "lldb",
            "request": "launch",
            "name": "Debug REPL",
            "cargo": {
                "args": [
                    "build",
                    "--example",
                    "ferlium"
                ]
            },
            "program": "${workspaceFolder}/target/debug/examples/ferlium",
            "args": [
                "--print-ssa"
            ],
            "env": {
                "RUST_BACKTRACE": "1"
            }
        }
    ]
}
